#!/bin/bash
# pve-status — Query Proxmox node/CT status
# Usage: pve-status <pve1|pve2|all> [node|cts|ct <id>]

PVE1_TOKEN="PVEAPIToken=claude@pve!claude-API=56043bd7-adee-4e1d-ad99-f4e37b5e3b29"
PVE2_TOKEN="PVEAPIToken=claude@pve!claude-API=2dc09344-ca7b-4d9c-8f69-543f56152234"

pve_curl() {
  local node=$1
  local path=$2
  local host token
  case $node in
    pve1) host="192.168.1.251"; token="$PVE1_TOKEN" ;;
    pve2) host="192.168.1.252"; token="$PVE2_TOKEN" ;;
    *) echo "Unknown node: $node"; return 1 ;;
  esac
  curl -sk -H "Authorization: $token" "https://$host:8006/api2/json$path"
}

node_status() {
  local node=$1
  pve_curl "$node" "/nodes/$node/status" | python3 -c "
import json, sys, os
node = '$node'
data = json.load(sys.stdin).get('data', {})
cpu = data.get('cpu', 0) * 100
mem = data.get('memory', {})
mem_used = mem.get('used', 0) / 1024**3
mem_total = mem.get('total', 0) / 1024**3
uptime_s = data.get('uptime', 0)
days = uptime_s // 86400
hours = (uptime_s % 86400) // 3600
print(f'{node}: CPU {cpu:.0f}% | RAM {mem_used:.1f}/{mem_total:.1f} GB | Uptime {days}d {hours}h')
"
}

list_cts() {
  local node=$1
  pve_curl "$node" "/nodes/$node/lxc" | python3 -c "
import json, sys
cts = json.load(sys.stdin).get('data', [])
cts.sort(key=lambda c: int(c.get('vmid', 0)))
for ct in cts:
    vmid = ct.get('vmid', '?')
    name = ct.get('name', '?')
    status = ct.get('status', '?')
    cpu = ct.get('cpu', 0) * 100
    mem = ct.get('mem', 0) / 1024**2
    maxmem = ct.get('maxmem', 0) / 1024**2
    print(f'CT {vmid:>4} {name:20} {status:8} CPU {cpu:4.0f}% MEM {mem:6.0f}/{maxmem:.0f} MB')
"
}

ct_status() {
  local node=$1
  local ctid=$2
  pve_curl "$node" "/nodes/$node/lxc/$ctid/status/current" | python3 -c "
import json, sys
ctid = '$ctid'
data = json.load(sys.stdin).get('data', {})
if not data:
    print('CT not found')
    sys.exit(1)
name = data.get('name', '?')
status = data.get('status', '?')
cpu = data.get('cpu', 0) * 100
mem = data.get('mem', 0) / 1024**2
maxmem = data.get('maxmem', 0) / 1024**2
disk = data.get('disk', 0) / 1024**3
maxdisk = data.get('maxdisk', 0) / 1024**3
uptime_s = data.get('uptime', 0)
days = uptime_s // 86400
hours = (uptime_s % 86400) // 3600
netin = data.get('netin', 0) / 1024**2
netout = data.get('netout', 0) / 1024**2
print(f'CT {ctid} ({name}): {status}')
print(f'  CPU: {cpu:.0f}%')
print(f'  RAM: {mem:.0f}/{maxmem:.0f} MB')
print(f'  Disk: {disk:.1f}/{maxdisk:.1f} GB')
print(f'  Net: in {netin:.0f} MB / out {netout:.0f} MB')
print(f'  Uptime: {days}d {hours}h')
"
}

case "$1" in
  all)
    node_status pve1
    node_status pve2
    ;;
  pve1|pve2)
    case "${2:-node}" in
      node) node_status "$1" ;;
      cts) list_cts "$1" ;;
      ct) ct_status "$1" "$3" ;;
      *) echo "Usage: pve-status <pve1|pve2> [node|cts|ct <id>]" ;;
    esac
    ;;
  *)
    echo "Usage: pve-status <pve1|pve2|all> [node|cts|ct <id>]"
    echo "Examples:"
    echo "  pve-status all             # Both nodes"
    echo "  pve-status pve1 cts        # List CTs on pve1"
    echo "  pve-status pve2 ct 230     # CT 230 details"
    ;;
esac
