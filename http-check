#!/bin/bash
# http-check — Check HTTP status code of services
# Usage: http-check <service|url> [service2 ...] | http-check all

KNOWN_SERVICES=(
  authentik vaultwarden forgejo traefik homepage
  linkwarden drawio excalidraw bytestash
  kavita immich jellyfin beszel wazuh patchmon
  headscale technitium wikinfra freshrss the-lounge pentagi homeassistant
)

declare -A SERVICE_URLS
SERVICE_URLS=(
  [authentik]=https://authentik.pixelium.internal
  [vaultwarden]=https://vaultwarden.pixelium.internal
  [forgejo]=https://forgejo.pixelium.internal
  [traefik]=https://traefik.pixelium.internal
  [homepage]=https://homepage.pixelium.internal
  [linkwarden]=https://linkwarden.pixelium.internal
  [drawio]=https://drawio.pixelium.internal/draw/
  [excalidraw]=https://excalidraw.pixelium.internal
  [bytestash]=https://bytestash.pixelium.internal
  [kavita]=https://kavita.pixelium.internal
  [immich]=https://immich.pixelium.internal
  [jellyfin]=https://jellyfin.pixelium.internal
  [beszel]=https://beszel.pixelium.internal
  [wazuh]=https://wazuh.pixelium.internal
  [patchmon]=https://patchmon.pixelium.internal
  [victoriametrics]=https://victoriametrics.pixelium.internal
  [semaphore]=https://semaphore.pixelium.internal
  [netbox]=https://netbox.pixelium.internal
  [openfang]=http://192.168.1.192:50051
  [headscale]=http://192.168.1.106:8080
  [technitium]=http://192.168.1.100:5380
  [wikinfra]=https://wikinfra.pixelium.internal
  [freshrss]=https://freshrss.pixelium.internal
  [the-lounge]=https://the-lounge.pixelium.internal
  [pentagi]=https://pentagi.pixelium.internal
  [homeassistant]=https://homeassistant.pixelium.internal
)

check_url() {
  local name=$1
  local url=$2
  local code
  code=$(curl -sk -o /dev/null -w "%{http_code}" --connect-timeout 5 --max-time 10 "$url" 2>/dev/null)
  local exit_code=$?
  if [ $exit_code -ne 0 ]; then
    echo "$name: FAIL (connection error)"
  elif [ "$code" -ge 200 ] 2>/dev/null && [ "$code" -lt 400 ]; then
    echo "$name: OK ($code)"
  elif [ "$code" -ge 400 ] 2>/dev/null && [ "$code" -lt 500 ]; then
    echo "$name: WARN ($code)"
  else
    echo "$name: ERROR ($code)"
  fi
}

if [ $# -eq 0 ]; then
  echo "Usage: http-check <service|url> [service2 ...] | http-check all"
  echo "Services: ${KNOWN_SERVICES[*]}"
  exit 1
fi

if [ "$1" = "all" ]; then
  for svc in "${KNOWN_SERVICES[@]}"; do
    check_url "$svc" "${SERVICE_URLS[$svc]}"
  done
  exit 0
fi

for arg in "$@"; do
  if [[ -n "${SERVICE_URLS[$arg]}" ]]; then
    check_url "$arg" "${SERVICE_URLS[$arg]}"
  elif [[ "$arg" == http* ]]; then
    check_url "$arg" "$arg"
  else
    echo "$arg: unknown service (try: http-check all)"
  fi
done
